{
  "name": "@finagra/mcp",
  "version": "0.1.0",
  "description": "Finagra Unity \u2014 Agentic MCP server exposing AgTech platform tools to Claude",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --loader ts-node/esm src/server.ts",
